{
  "hooks": {
    "UserPromptSubmit": [
      {
        "description": "Improves user prompts by adding clarifying questions",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/improve-prompt.py || python ${CLAUDE_PLUGIN_ROOT}/scripts/improve-prompt.py",
            "description": "Run the prompt improvement script"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "description": "Injects plan readability guidance when entering plan mode",
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/plan-guidance.py || python ${CLAUDE_PLUGIN_ROOT}/scripts/plan-guidance.py"
          }
        ]
      }
    ]
  }
}
